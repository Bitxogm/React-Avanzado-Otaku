# Archivo de ejemplo de Variables de Entorno.
# Para que la App funcione, debes crear un archivo llamado ".env" al mismo nivel que este,
# y copiar el contenido de aquí adentro con tus credenciales reales.

# Cadena de conexión para Prisma ORM. Sigue el formato: 
# postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5433/nextjs_db?schema=public"
JWT_SECRET="tu_secreto_para_jwt_aqui"